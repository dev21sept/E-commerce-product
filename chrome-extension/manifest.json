{
  "manifest_version": 3,
  "name": "eBay Auto Lister",
  "version": "1.0",
  "description": "Auto-fills eBay listing forms from Admin Panel data.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://*.ebay.com/*",
    "https://*.ebay.co.uk/*",
    "https://*.ebay.de/*",
    "https://*.ebay.ca/*",
    "https://*.ebay.com.au/*",
    "https://*.ebay.in/*",
    "https://*.ebay.ie/*",
    "https://*.ebay.at/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
         "<all_urls>"
      ],
      "js": ["admin_content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.ebay.com/*",
        "*://*.ebay.co.uk/*",
        "*://*.ebay.de/*",
        "*://*.ebay.ca/*",
        "*://*.ebay.com.au/*",
        "*://*.ebay.in/*",
        "*://*.ebay.ie/*",
        "*://*.ebay.at/*"
      ],
      "js": ["ebay_content.js"],
      "run_at": "document_idle"
    }
  ]
}
